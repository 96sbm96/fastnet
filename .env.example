# ============================================
# FastNet Smart Card Store - Environment Variables
# ============================================

# Application
NODE_ENV=development
PORT=3000
APP_SECRET=your_secret_key_here_change_in_production

# Database (MySQL)
DATABASE_URL=mysql://fastnet:fastnet_password@localhost:3306/fastnet

# Redis (for caching and queues)
REDIS_URL=redis://localhost:6379

# Kimi OAuth (Authentication)
VITE_APP_ID=your_app_id
VITE_KIMI_AUTH_URL=https://kimi-auth-url
KIMI_AUTH_URL=https://kimi-auth-url
OWNER_UNION_ID=admin_union_id

# MikroTik Hotspot Settings
MIKROTIK_ADDRESS=192.168.88.1
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=
DEFAULT_LOGIN_PAGE=http://192.168.88.1/login

# Payment Gateway Settings (Encrypted)
# FLOOSAK_API_KEY=
# FLOOSAK_API_SECRET=
# JEEB_API_KEY=
# KREAMY_API_KEY=
# JAWALI_API_KEY=
